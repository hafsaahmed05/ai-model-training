# ══════════════════════════════════════════════
#  AI-MODEL-TRAINING  –  .gitignore
# ══════════════════════════════════════════════
# ── Python ─────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ────────────────────────
.venv/
venv/
env/
ENV/

# ── Model weights ───────────────────────────────
# Large binary files – don't commit, share via Drive/Colab
part1_fashion_mnist/outputs/*.pth
part2_lunar_lander/outputs/*.pth

# ── Training logs & generated plots ─────────────
part1_fashion_mnist/outputs/
part2_lunar_lander/outputs/

# ── Downloaded datasets ──────────────────────────
# FashionMNIST downloads to data/ automatically
part1_fashion_mnist/data/

# ── Demo video ───────────────────────────────────
*.mp4
*.gif
*.avi

# ── OS junk ─────────────────────────────────────
.DS_Store

# ── Misc ────────────────────────────────────────
*.log
*.tmp
*.bak